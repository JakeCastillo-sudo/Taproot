# Taproot POS — environment variables (see docs/RAILWAY_ENV.md for the deployed set)
# Copy to apps/api/.env for local dev. Never commit real secrets.

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://localhost:5432/taproot_dev
REDIS_URL=redis://localhost:6379

# ── Auth / crypto ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-prod
JWT_REFRESH_SECRET=change-me-in-prod
ENCRYPTION_KEY=change-me-32-byte-hex   # AES-256-GCM key (offline card vault)

# ── Stripe (payments + Connect ISV) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
# Frontend (apps/web): VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── AI (menu import, NL query, intelligence layer) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6        # optional override

# ── Twilio (S7-01 AI text ordering) — optional; logs to console when unset ────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Frontend (apps/web) ──────────────────────────────────────────────────────
# VITE_API_URL=                         # empty = Vite proxy → localhost:3001
# VITE_PLAUSIBLE_DOMAIN=app.taprootpos.com
