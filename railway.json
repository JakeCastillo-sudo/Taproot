{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --include=dev && npm run build --workspace=@taproot/shared && npm run build --workspace=@taproot/api"
  },
  "deploy": {
    "startCommand": "sh scripts/startup.sh",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "networking": {
    "serviceDomains": {
      "taproot-production.up.railway.app": {
        "port": 8080
      }
    }
  }
}
