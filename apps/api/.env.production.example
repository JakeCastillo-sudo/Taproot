# ─────────────────────────────────────────────────────────────────────────────
# Taproot POS — Production environment template
# Copy to .env when deploying to production.
# ⚠️  NEVER commit the real .env — only this .example template.
# ⚠️  Use sk_live_ Stripe keys (NOT sk_test_) in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Must include ?sslmode=require for production
DATABASE_URL=postgresql://taproot_app:CHANGE_ME@prod-db.example.com:5432/taproot_prod?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://prod-redis.example.com:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# MUST be different from staging secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_MINIMUM_64_RANDOM_CHARACTERS_PRODUCTION_ONLY_VALUE
JWT_REFRESH_SECRET=CHANGE_ME_MINIMUM_64_RANDOM_CHARACTERS_DIFFERENT_FROM_ACCESS_JWT

# ── MFA & Encryption ─────────────────────────────────────────────────────────
MFA_TOKEN_SECRET=CHANGE_ME_MINIMUM_64_RANDOM_CHARACTERS_PRODUCTION_MFA_SECRET
MFA_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_EXACTLY_32_BYTES_PRODUCTION_AES256
OFFLINE_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_EXACTLY_32_BYTES_PRODUCTION_OFFLINE

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Stripe (LIVE keys — use sk_live_ prefix) ─────────────────────────────────
# ⚠️  These process real payments. Double-check before deploying.
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_TERMINAL_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://app.taprootpos.com
CORS_ORIGINS=https://app.taprootpos.com

# ── Monitoring ────────────────────────────────────────────────────────────────
METRICS_SECRET=CHANGE_ME_64_CHAR_STRONG_RANDOM_SECRET_FOR_PROMETHEUS

# ── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME_SENDGRID_API_KEY
EMAIL_FROM=noreply@taprootpos.com

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOADS_DIR=/opt/taproot/uploads
