# ─────────────────────────────────────────────────────────────────────────────
# Taproot POS — Staging environment template
# Copy to .env when deploying to the staging server.
# NEVER commit the real .env file — only this .example template.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://taproot_app:CHANGE_ME@staging-db.example.com:5432/taproot_staging?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://staging-redis.example.com:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_MINIMUM_64_RANDOM_CHARACTERS_HEX_ENCODED_STRING_HERE
JWT_REFRESH_SECRET=CHANGE_ME_MINIMUM_64_RANDOM_CHARACTERS_DIFFERENT_FROM_ACCESS_JWT

# ── MFA & Encryption ─────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_TOKEN_SECRET=CHANGE_ME_MINIMUM_64_RANDOM_CHARACTERS_FOR_MFA_TOKEN_SIGNING
MFA_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_EXACTLY_32_BYTES_FOR_AES256_KEY
OFFLINE_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_EXACTLY_32_BYTES_DIFFERENT_FROM_MFA

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Stripe (use TEST keys for staging) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_TERMINAL_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=staging
PORT=3001
APP_URL=https://staging.taprootpos.com
CORS_ORIGINS=https://staging.taprootpos.com

# ── Monitoring ────────────────────────────────────────────────────────────────
# Protects GET /metrics — set to a strong random string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
METRICS_SECRET=CHANGE_ME_64_CHAR_SECRET_FOR_PROMETHEUS_SCRAPING

# ── Email (optional for staging) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=staging@example.com
SMTP_PASS=CHANGE_ME
EMAIL_FROM=noreply@staging.taprootpos.com

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOADS_DIR=/opt/taproot/uploads
