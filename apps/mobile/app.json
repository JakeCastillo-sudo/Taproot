{
  "expo": {
    "name": "Taproot POS",
    "slug": "taproot-pos",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D9E75"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taproot.pos",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Taproot uses your camera to scan product barcodes.",
        "NSBluetoothAlwaysUsageDescription": "Taproot connects to Bluetooth payment terminals.",
        "NSBluetoothPeripheralUsageDescription": "Taproot connects to Bluetooth payment terminals.",
        "NSLocationWhenInUseUsageDescription": "Taproot uses location to find nearby card readers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D9E75"
      },
      "package": "com.taproot.pos",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.taproot.pos",
          "enableGooglePay": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Taproot uses your camera to scan product barcodes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1D9E75"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
